<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>Meg-Music</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700;800&family=Roboto+Mono:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --bg: #050505;
      --bg2: #0a0a0a;
      --bg3: #111111;
      --bg4: #181818;
      --border: #1f1f1f;
      --border2: #2a2a2a;
      --em: #10b981;
      --em2: #06b6d4;
      --em-glow: rgba(16,185,129,0.18);
      --em2-glow: rgba(6,182,212,0.15);
      --text: #e4e4e7;
      --text2: #71717a;
      --text3: #3f3f46;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; overflow: hidden; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'JetBrains Mono', 'Roboto Mono', monospace;
      font-size: 13px;
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--bg2); }
    ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--em); }

    /* Layout */
    #app { display: flex; flex-direction: column; height: 100vh; }
    #main-layout { display: flex; flex: 1; overflow: hidden; }

    /* Sidebar */
    #sidebar {
      width: 220px;
      min-width: 220px;
      background: var(--bg2);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow-y: auto;
      overflow-x: hidden;
    }

    /* Content */
    #content {
      flex: 1;
      overflow-y: auto;
      background: var(--bg);
      padding: 20px;
    }

    /* Player Bar */
    #player-bar {
      height: 72px;
      background: var(--bg2);
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 12px;
      flex-shrink: 0;
      position: relative;
      z-index: 100;
    }

    /* Modal */
    #modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.85);
      display: flex; align-items: center; justify-content: center;
      z-index: 999; backdrop-filter: blur(8px);
    }
    #modal-box {
      background: var(--bg3);
      border: 1px solid var(--em);
      border-radius: 2px;
      padding: 32px 28px;
      width: 320px;
      box-shadow: 0 0 40px var(--em-glow), 0 0 80px rgba(16,185,129,0.05);
    }
    .modal-title {
      font-size: 15px; font-weight: 700; color: var(--em);
      text-transform: uppercase; letter-spacing: 3px;
      margin-bottom: 6px;
    }
    .modal-sub { color: var(--text2); font-size: 11px; margin-bottom: 24px; }
    #name-input {
      width: 100%; background: var(--bg);
      border: 1px solid var(--border2); color: var(--text);
      padding: 10px 12px; font-family: inherit; font-size: 13px;
      outline: none; border-radius: 1px;
      transition: border-color 0.2s;
    }
    #name-input:focus { border-color: var(--em); box-shadow: 0 0 0 2px var(--em-glow); }
    #enter-btn {
      width: 100%; margin-top: 14px; background: var(--em);
      color: #000; border: none; padding: 11px;
      font-family: inherit; font-weight: 700; font-size: 12px;
      letter-spacing: 2px; text-transform: uppercase;
      cursor: pointer; border-radius: 1px;
      transition: background 0.2s, box-shadow 0.2s;
    }
    #enter-btn:hover { background: #34d399; box-shadow: 0 0 16px var(--em-glow); }

    /* Sidebar User */
    .sidebar-user {
      padding: 16px 14px 12px;
      border-bottom: 1px solid var(--border);
    }
    .user-tag {
      font-size: 9px; color: var(--em); letter-spacing: 3px;
      text-transform: uppercase; margin-bottom: 4px;
    }
    .user-name {
      font-size: 14px; font-weight: 700; color: var(--text);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .user-status {
      display: flex; align-items: center; gap: 5px;
      font-size: 10px; color: var(--text2); margin-top: 4px;
    }
    .status-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--em); flex-shrink: 0;
      box-shadow: 0 0 6px var(--em);
      animation: pulse-dot 2s infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; } 50% { opacity: 0.4; }
    }

    /* Sidebar Nav */
    .sidebar-section-label {
      padding: 14px 14px 5px;
      font-size: 9px; letter-spacing: 3px; color: var(--text3);
      text-transform: uppercase;
    }
    .nav-item {
      display: flex; align-items: center; gap: 9px;
      padding: 9px 14px; cursor: pointer;
      color: var(--text2); font-size: 12px;
      border-left: 2px solid transparent;
      transition: all 0.15s; user-select: none;
    }
    .nav-item:hover { color: var(--text); background: var(--bg3); }
    .nav-item.active {
      color: var(--em); border-left-color: var(--em);
      background: var(--em-glow);
    }
    .nav-icon { width: 14px; text-align: center; flex-shrink: 0; }

    /* Playlist items */
    .playlist-item {
      display: flex; align-items: center; justify-content: space-between;
      padding: 7px 14px; cursor: pointer;
      color: var(--text2); font-size: 11px;
      border-left: 2px solid transparent;
      transition: all 0.15s;
    }
    .playlist-item:hover { color: var(--text); background: var(--bg3); }
    .playlist-item.active { color: var(--em2); border-left-color: var(--em2); background: var(--em2-glow); }
    .playlist-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; }
    .playlist-count { font-size: 10px; color: var(--text3); flex-shrink: 0; margin-left: 6px; }

    .create-btn {
      margin: 8px 14px 4px;
      display: flex; align-items: center; gap: 7px;
      padding: 7px 10px; background: var(--bg3);
      border: 1px dashed var(--border2); cursor: pointer;
      color: var(--text2); font-size: 11px; font-family: inherit;
      border-radius: 1px; width: calc(100% - 28px);
      transition: all 0.15s;
    }
    .create-btn:hover { border-color: var(--em); color: var(--em); }

    /* Search Bar */
    .search-wrap {
      display: flex; gap: 8px; margin-bottom: 20px;
    }
    #search-input {
      flex: 1; background: var(--bg3); border: 1px solid var(--border2);
      color: var(--text); padding: 10px 14px;
      font-family: inherit; font-size: 13px; outline: none;
      border-radius: 1px; transition: border-color 0.2s;
    }
    #search-input:focus { border-color: var(--em); box-shadow: 0 0 0 2px var(--em-glow); }
    #search-input::placeholder { color: var(--text3); }
    #search-btn {
      background: var(--em); color: #000; border: none;
      padding: 10px 18px; font-family: inherit; font-weight: 700;
      font-size: 12px; cursor: pointer; letter-spacing: 1px;
      border-radius: 1px; transition: all 0.15s; flex-shrink: 0;
    }
    #search-btn:hover { background: #34d399; box-shadow: 0 0 12px var(--em-glow); }
    #search-btn:active { transform: scale(0.97); }

    /* Section Header */
    .section-header {
      display: flex; align-items: baseline; gap: 10px; margin-bottom: 14px;
    }
    .section-title {
      font-size: 13px; font-weight: 700; letter-spacing: 2px;
      text-transform: uppercase; color: var(--text);
    }
    .section-accent { color: var(--em); }
    .section-tag {
      font-size: 9px; color: var(--text3); letter-spacing: 2px;
      text-transform: uppercase;
    }

    /* Song Grid */
    .song-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 12px;
      margin-bottom: 28px;
    }
    .song-card {
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 2px;
      cursor: pointer;
      transition: all 0.2s;
      overflow: hidden;
      position: relative;
    }
    .song-card:hover {
      border-color: var(--em);
      box-shadow: 0 0 14px var(--em-glow);
      transform: translateY(-2px);
    }
    .song-card.playing {
      border-color: var(--em2);
      box-shadow: 0 0 18px var(--em2-glow);
    }
    .song-thumb-wrap {
      position: relative;
      padding-top: 56.25%; /* 16:9 */
      overflow: hidden;
      background: var(--bg4);
    }
    .song-thumb {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; transition: transform 0.3s;
    }
    .song-card:hover .song-thumb { transform: scale(1.05); }
    .play-overlay {
      position: absolute; inset: 0;
      background: rgba(0,0,0,0.5);
      display: flex; align-items: center; justify-content: center;
      opacity: 0; transition: opacity 0.2s;
    }
    .song-card:hover .play-overlay { opacity: 1; }
    .play-icon-big {
      width: 36px; height: 36px; background: var(--em);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      box-shadow: 0 0 16px var(--em-glow);
    }
    .song-info { padding: 9px 10px; }
    .song-title {
      font-size: 11px; font-weight: 600; color: var(--text);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      margin-bottom: 3px;
    }
    .song-artist { font-size: 10px; color: var(--text2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .add-to-playlist-btn {
      position: absolute; top: 6px; right: 6px;
      background: rgba(0,0,0,0.75); border: 1px solid var(--border2);
      color: var(--text2); width: 24px; height: 24px;
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      cursor: pointer; font-size: 13px; opacity: 0;
      transition: all 0.15s; z-index: 5;
    }
    .song-card:hover .add-to-playlist-btn { opacity: 1; }
    .add-to-playlist-btn:hover { border-color: var(--em2); color: var(--em2); background: rgba(6,182,212,0.2); }

    /* Playing indicator */
    .eq-bars {
      display: flex; align-items: flex-end; gap: 2px;
      height: 14px;
    }
    .eq-bar {
      width: 3px; background: var(--em2); border-radius: 1px;
      animation: eq-anim 0.6s infinite alternate;
    }
    .eq-bar:nth-child(1) { animation-duration: 0.5s; height: 6px; }
    .eq-bar:nth-child(2) { animation-duration: 0.7s; height: 10px; }
    .eq-bar:nth-child(3) { animation-duration: 0.4s; height: 8px; }
    @keyframes eq-anim {
      from { transform: scaleY(0.4); }
      to { transform: scaleY(1); }
    }

    /* Loading skeleton */
    .skeleton {
      background: linear-gradient(90deg, var(--bg3) 25%, var(--bg4) 50%, var(--bg3) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
      border-radius: 2px;
    }
    @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

    /* Empty state */
    .empty-state {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 60px 20px; color: var(--text3); text-align: center;
    }
    .empty-icon { font-size: 40px; margin-bottom: 12px; opacity: 0.4; }
    .empty-title { font-size: 13px; font-weight: 600; color: var(--text2); margin-bottom: 4px; }
    .empty-sub { font-size: 11px; }

    /* Toast */
    #toast {
      position: fixed; bottom: 86px; right: 14px; z-index: 999;
      background: var(--bg3); border: 1px solid var(--em2);
      color: var(--text); padding: 10px 14px; font-size: 11px;
      border-radius: 2px; box-shadow: 0 0 16px var(--em2-glow);
      transform: translateY(10px) scale(0.97); opacity: 0;
      transition: all 0.2s; pointer-events: none;
      max-width: 240px;
    }
    #toast.show { transform: translateY(0) scale(1); opacity: 1; }

    /* Playlist Modal */
    #playlist-modal {
      position: fixed; inset: 0; background: rgba(0,0,0,0.8);
      display: none; align-items: center; justify-content: center; z-index: 500;
      backdrop-filter: blur(6px);
    }
    #playlist-modal.open { display: flex; }
    .pmodal-box {
      background: var(--bg3); border: 1px solid var(--border2);
      border-radius: 2px; padding: 24px; width: 300px;
      box-shadow: 0 0 30px rgba(0,0,0,0.6);
    }
    .pmodal-title { font-size: 13px; font-weight: 700; color: var(--em2); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px; }
    .pmodal-item {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 0; cursor: pointer; border-bottom: 1px solid var(--border);
      transition: color 0.15s;
    }
    .pmodal-item:hover { color: var(--em); }
    .pmodal-item:last-child { border-bottom: none; }
    .pmodal-close {
      margin-top: 14px; width: 100%; background: transparent;
      border: 1px solid var(--border2); color: var(--text2);
      padding: 8px; font-family: inherit; font-size: 11px;
      cursor: pointer; border-radius: 1px; transition: all 0.15s;
    }
    .pmodal-close:hover { border-color: var(--text2); color: var(--text); }

    /* New Playlist Input Modal */
    #newpl-modal {
      position: fixed; inset: 0; background: rgba(0,0,0,0.8);
      display: none; align-items: center; justify-content: center; z-index: 501;
      backdrop-filter: blur(6px);
    }
    #newpl-modal.open { display: flex; }
    .newpl-box {
      background: var(--bg3); border: 1px solid var(--em);
      border-radius: 2px; padding: 24px; width: 280px;
    }
    #newpl-input {
      width: 100%; background: var(--bg); border: 1px solid var(--border2);
      color: var(--text); padding: 9px 12px; font-family: inherit; font-size: 12px;
      outline: none; border-radius: 1px; margin-bottom: 12px;
    }
    #newpl-input:focus { border-color: var(--em); }
    .newpl-actions { display: flex; gap: 8px; }
    .btn-em {
      flex: 1; background: var(--em); color: #000; border: none;
      padding: 9px; font-family: inherit; font-weight: 700; font-size: 11px;
      letter-spacing: 1px; cursor: pointer; border-radius: 1px;
    }
    .btn-ghost {
      flex: 1; background: transparent; color: var(--text2);
      border: 1px solid var(--border2); padding: 9px;
      font-family: inherit; font-size: 11px; cursor: pointer; border-radius: 1px;
    }
    .btn-ghost:hover { border-color: var(--text2); color: var(--text); }

    /* Player Bar Styles */
    .player-thumb {
      width: 46px; height: 46px; object-fit: cover;
      border-radius: 1px; flex-shrink: 0;
      border: 1px solid var(--border);
    }
    .player-info { flex: 1; min-width: 0; }
    .player-title {
      font-size: 12px; font-weight: 600; color: var(--text);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .player-artist { font-size: 10px; color: var(--text2); }

    .player-controls { display: flex; flex-direction: column; align-items: center; gap: 5px; flex: 1.5; }
    .ctrl-btns { display: flex; align-items: center; gap: 14px; }
    .ctrl-btn {
      background: none; border: none; color: var(--text2);
      cursor: pointer; padding: 4px; border-radius: 50%;
      transition: all 0.15s; display: flex;
    }
    .ctrl-btn:hover { color: var(--text); }
    #play-pause-btn {
      background: var(--em); color: #000 !important; width: 34px; height: 34px;
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      box-shadow: 0 0 10px var(--em-glow);
      transition: all 0.15s;
    }
    #play-pause-btn:hover { background: #34d399; box-shadow: 0 0 16px var(--em-glow); transform: scale(1.06); }

    .progress-wrap { display: flex; align-items: center; gap: 8px; width: 100%; max-width: 360px; }
    .time-label { font-size: 10px; color: var(--text3); flex-shrink: 0; width: 34px; text-align: center; }
    #progress-bar {
      flex: 1; height: 3px; background: var(--border2);
      cursor: pointer; border-radius: 2px; position: relative;
      -webkit-appearance: none; appearance: none;
    }
    #progress-bar::-webkit-slider-thumb {
      -webkit-appearance: none; width: 12px; height: 12px;
      border-radius: 50%; background: var(--em); cursor: pointer;
      box-shadow: 0 0 6px var(--em-glow);
    }
    #progress-bar::-webkit-slider-runnable-track {
      height: 3px; border-radius: 2px;
      background: linear-gradient(to right, var(--em) var(--progress, 0%), var(--border2) var(--progress, 0%));
    }

    .player-right { display: flex; align-items: center; gap: 8px; }
    #volume-bar {
      width: 70px; height: 3px; -webkit-appearance: none; appearance: none;
      background: var(--border2); border-radius: 2px; cursor: pointer;
    }
    #volume-bar::-webkit-slider-thumb {
      -webkit-appearance: none; width: 10px; height: 10px;
      border-radius: 50%; background: var(--em2); cursor: pointer;
    }
    #volume-bar::-webkit-slider-runnable-track {
      height: 3px; border-radius: 2px;
      background: linear-gradient(to right, var(--em2) var(--vol, 80%), var(--border2) var(--vol, 80%));
    }

    /* Banner Section */
    .banner-section {
      background: linear-gradient(135deg, var(--bg3) 0%, #0d1a14 50%, var(--bg3) 100%);
      border: 1px solid var(--border);
      border-left: 3px solid var(--em);
      padding: 16px 18px;
      margin-bottom: 20px;
      border-radius: 2px;
      position: relative; overflow: hidden;
    }
    .banner-section::before {
      content: ''; position: absolute; top: -30px; right: -30px;
      width: 120px; height: 120px; border-radius: 50%;
      background: radial-gradient(circle, var(--em-glow) 0%, transparent 70%);
      pointer-events: none;
    }
    .banner-label {
      font-size: 9px; letter-spacing: 3px; color: var(--em); text-transform: uppercase; margin-bottom: 4px;
    }
    .banner-title {
      font-size: 16px; font-weight: 800; color: var(--text); letter-spacing: 1px;
    }

    /* Responsive - Mobile First */
    @media (max-width: 640px) {
      #sidebar { width: 180px; min-width: 180px; }
      #content { padding: 14px 12px; }
      .song-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 9px; }
      .player-right { display: none; }
      .player-info { max-width: 90px; }
      #player-bar { gap: 8px; padding: 0 10px; }
    }

    @media (max-width: 480px) {
      #sidebar { display: none; }
      #main-layout { flex-direction: column; }
    }

    /* Spinner */
    .spinner {
      width: 24px; height: 24px; border: 2px solid var(--border2);
      border-top-color: var(--em); border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .loading-row { display: flex; align-items: center; justify-content: center; padding: 40px; }

    input[type="range"] { cursor: pointer; }

    /* Cyberpunk scan line overlay */
    body::after {
      content: '';
      position: fixed; inset: 0; pointer-events: none; z-index: 9999;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.03) 2px,
        rgba(0,0,0,0.03) 4px
      );
    }
  </style>
</head>
<body>

<!-- NAME MODAL -->
<div id="modal-overlay">
  <div id="modal-box">
    <div class="modal-title">// MEG-MUSIC</div>
    <div class="modal-sub">Masukkan nama identitas kamu untuk memulai sesi.</div>
    <input type="text" id="name-input" placeholder="nama_kamu" maxlength="24" autocomplete="off" />
    <button id="enter-btn" onclick="submitName()">▶ MASUK SISTEM</button>
  </div>
</div>

<!-- PLAYLIST MODAL (choose playlist) -->
<div id="playlist-modal">
  <div class="pmodal-box">
    <div class="pmodal-title">// Tambah ke Playlist</div>
    <div id="pmodal-list"></div>
    <button class="pmodal-close" onclick="closePModal()">✕ BATAL</button>
  </div>
</div>

<!-- NEW PLAYLIST MODAL -->
<div id="newpl-modal">
  <div class="newpl-box">
    <div class="pmodal-title">// Playlist Baru</div>
    <input type="text" id="newpl-input" placeholder="Nama playlist..." maxlength="30" />
    <div class="newpl-actions">
      <button class="btn-em" onclick="confirmNewPlaylist()">BUAT</button>
      <button class="btn-ghost" onclick="closeNewPLModal()">Batal</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div id="toast"></div>

<!-- APP -->
<div id="app">
  <div id="main-layout">

    <!-- SIDEBAR -->
    <div id="sidebar">
      <!-- User Info -->
      <div class="sidebar-user">
        <div class="user-tag">// USER</div>
        <div class="user-name" id="sidebar-username">—</div>
        <div class="user-status">
          <div class="status-dot"></div>
          <span>ONLINE</span>
        </div>
      </div>

      <!-- Navigation -->
      <div class="sidebar-section-label">NAVIGASI</div>
      <div class="nav-item active" id="nav-home" onclick="navigate('home')">
        <span class="nav-icon">⌂</span> Home
      </div>
      <div class="nav-item" id="nav-indonesia" onclick="navigate('indonesia')">
        <span class="nav-icon">🇮🇩</span> Top Indonesia
      </div>
      <div class="nav-item" id="nav-global" onclick="navigate('global')">
        <span class="nav-icon">◎</span> Top Global
      </div>

      <!-- Playlists -->
      <div class="sidebar-section-label" style="margin-top:8px;">MY PLAYLIST</div>
      <button class="create-btn" onclick="openNewPLModal()">
        <span>+</span> Create New
      </button>
      <div id="playlist-list"></div>
    </div>

    <!-- CONTENT -->
    <div id="content">

      <!-- HOME -->
      <div id="view-home">
        <!-- Search -->
        <div class="search-wrap">
          <input type="text" id="search-input" placeholder="Cari lagu, artist..." />
          <button id="search-btn" onclick="doSearch()">CARI</button>
        </div>

        <!-- Search results or default home -->
        <div id="search-results-wrap" style="display:none">
          <div class="section-header">
            <span class="section-title">HASIL <span class="section-accent">PENCARIAN</span></span>
            <span class="section-tag" id="search-count-label"></span>
          </div>
          <div id="search-results" class="song-grid"></div>
        </div>

        <div id="home-default">
          <div class="banner-section">
            <div class="banner-label">// MEG-MUSIC SYSTEM</div>
            <div class="banner-title">SELAMAT DATANG</div>
            <div style="color:var(--text2);font-size:11px;margin-top:6px;">Cari lagu favoritmu di atas, atau pilih Top Indonesia / Top Global di sidebar.</div>
          </div>

          <div class="section-header">
            <span class="section-title">🔥 TOP <span class="section-accent">INDONESIA</span></span>
          </div>
          <div id="top-indo" class="song-grid">
            <div class="loading-row" style="grid-column:1/-1;"><div class="spinner"></div></div>
          </div>

          <div class="section-header" style="margin-top:24px">
            <span class="section-title">🌐 TOP <span class="section-accent">GLOBAL</span></span>
          </div>
          <div id="top-global" class="song-grid">
            <div class="loading-row" style="grid-column:1/-1;"><div class="spinner"></div></div>
          </div>
        </div>
      </div>

      <!-- INDONESIA -->
      <div id="view-indonesia" style="display:none">
        <div class="section-header">
          <span class="section-title">🇮🇩 TOP <span class="section-accent">INDONESIA</span></span>
        </div>
        <div id="view-indo-grid" class="song-grid">
          <div class="loading-row" style="grid-column:1/-1;"><div class="spinner"></div></div>
        </div>
      </div>

      <!-- GLOBAL -->
      <div id="view-global" style="display:none">
        <div class="section-header">
          <span class="section-title">🌐 TOP <span class="section-accent">GLOBAL</span></span>
        </div>
        <div id="view-global-grid" class="song-grid">
          <div class="loading-row" style="grid-column:1/-1;"><div class="spinner"></div></div>
        </div>
      </div>

      <!-- PLAYLIST VIEW -->
      <div id="view-playlist" style="display:none">
        <div class="section-header">
          <span class="section-title">🎵 PLAYLIST: <span class="section-accent" id="current-pl-name">—</span></span>
          <button onclick="deletePlaylist()" style="background:none;border:none;color:var(--text3);font-size:10px;cursor:pointer;font-family:inherit;margin-left:auto;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='var(--text3)'">✕ Hapus</button>
        </div>
        <div id="playlist-songs" class="song-grid"></div>
      </div>

    </div>
  </div>

  <!-- PLAYER BAR -->
  <div id="player-bar">
    <!-- Left: Song Info -->
    <img id="player-thumb" class="player-thumb" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 46 46'%3E%3Crect fill='%23181818' width='46' height='46'/%3E%3Ctext x='50%25' y='50%25' dominant-baseline='middle' text-anchor='middle' fill='%233f3f46' font-size='20'%3E♪%3C/text%3E%3C/svg%3E" alt="thumb" />
    <div class="player-info">
      <div class="player-title" id="player-title">Tidak ada lagu</div>
      <div class="player-artist" id="player-artist">—</div>
    </div>

    <!-- Center: Controls -->
    <div class="player-controls">
      <div class="ctrl-btns">
        <button class="ctrl-btn" onclick="prevSong()" title="Sebelumnya">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/></svg>
        </button>
        <button class="ctrl-btn" id="play-pause-btn" onclick="togglePlay()">
          <svg id="play-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          <svg id="pause-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
        </button>
        <button class="ctrl-btn" onclick="nextSong()" title="Berikutnya">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18l8.5-6L6 6v12zm2-8.14L11.03 12 8 14.14V9.86zM16 6h2v12h-2z"/></svg>
        </button>
      </div>
      <div class="progress-wrap">
        <span class="time-label" id="time-current">0:00</span>
        <input type="range" id="progress-bar" min="0" max="100" value="0" step="0.1" oninput="seekTo(this.value)" />
        <span class="time-label" id="time-total">0:00</span>
      </div>
    </div>

    <!-- Right: Volume -->
    <div class="player-right">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--text2)"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0 0 14 7.97v8.05A4.5 4.5 0 0 0 16.5 12z"/></svg>
      <input type="range" id="volume-bar" min="0" max="100" value="80" oninput="setVolume(this.value)" />
    </div>
  </div>
</div>

<audio id="audio-player" preload="metadata"></audio>

<script>
// ============================================================
// STATE
// ============================================================
let currentUser = '';
let playlists = {};     // { name: [song, ...] }
let currentSong = null;
let currentQueue = [];
let currentQueueIndex = -1;
let isLoading = false;
let currentView = 'home';
let currentPlaylistName = '';
let pendingSong = null; // for add-to-playlist

const audio = document.getElementById('audio-player');

// Cache for top charts
const cache = { indo: null, global: null };

// ============================================================
// INIT
// ============================================================
window.onload = () => {
  const saved = localStorage.getItem('meg_user');
  if (saved) {
    currentUser = saved;
    initUser();
    document.getElementById('modal-overlay').style.display = 'none';
  }
  // Volume init
  audio.volume = 0.8;
  updateVolumeTrack(80);
};

function submitName() {
  const val = document.getElementById('name-input').value.trim();
  if (!val) { showToast('Masukkan nama dulu ya!'); return; }
  currentUser = val;
  localStorage.setItem('meg_user', val);
  initUser();
  document.getElementById('modal-overlay').style.display = 'none';
}

document.getElementById('name-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') submitName();
});

function initUser() {
  document.getElementById('sidebar-username').textContent = currentUser;
  loadPlaylists();
  loadTopCharts();
}

// ============================================================
// NAVIGATION
// ============================================================
function navigate(view) {
  currentView = view;
  ['home','indonesia','global','playlist'].forEach(v => {
    document.getElementById('view-' + v).style.display = v === view ? 'block' : 'none';
  });
  ['home','indonesia','global'].forEach(v => {
    const el = document.getElementById('nav-' + v);
    if (el) el.classList.toggle('active', v === view);
  });
  document.querySelectorAll('.playlist-item').forEach(el => {
    el.classList.toggle('active', el.dataset.name === currentPlaylistName && view === 'playlist');
  });

  if (view === 'indonesia') loadViewIndo();
  if (view === 'global') loadViewGlobal();
}

function openPlaylistView(name) {
  currentPlaylistName = name;
  document.getElementById('current-pl-name').textContent = name;
  renderPlaylistSongs(name);
  navigate('playlist');
  renderSidebarPlaylists();
}

// ============================================================
// SEARCH
// ============================================================
document.getElementById('search-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') doSearch();
});

async function doSearch() {
  const q = document.getElementById('search-input').value.trim();
  if (!q) return;

  document.getElementById('home-default').style.display = 'none';
  document.getElementById('search-results-wrap').style.display = 'block';
  document.getElementById('search-results').innerHTML = `<div class="loading-row" style="grid-column:1/-1;"><div class="spinner"></div></div>`;

  navigate('home');

  try {
    const res = await fetch(`/api/search?q=${encodeURIComponent(q)}`);
    const data = await res.json();
    if (data.error) throw new Error(data.error);

    document.getElementById('search-count-label').textContent = `${data.results.length} hasil`;
    currentQueue = data.results;

    document.getElementById('search-results').innerHTML =
      data.results.length ? data.results.map((s, i) => songCard(s, i, 'search-results')).join('') :
      `<div class="empty-state" style="grid-column:1/-1"><div class="empty-icon">🔍</div><div class="empty-title">Tidak ada hasil</div><div class="empty-sub">Coba kata kunci lain</div></div>`;
  } catch (err) {
    document.getElementById('search-results').innerHTML = `<div class="empty-state" style="grid-column:1/-1"><div class="empty-icon">⚠</div><div class="empty-title">Gagal mencari</div><div class="empty-sub">${err.message}</div></div>`;
  }
}

// ============================================================
// TOP CHARTS
// ============================================================
async function loadTopCharts() {
  loadIndo('top-indo');
  loadGlobal('top-global');
}

async function loadIndo(containerId) {
  if (cache.indo) { renderGrid(containerId, cache.indo, 'indo'); return; }
  try {
    const res = await fetch('/api/search?q=top+hits+indonesia+2024');
    const data = await res.json();
    cache.indo = data.results || [];
    renderGrid(containerId, cache.indo, 'indo');
  } catch {
    document.getElementById(containerId).innerHTML = errorState();
  }
}

async function loadGlobal(containerId) {
  if (cache.global) { renderGrid(containerId, cache.global, 'global'); return; }
  try {
    const res = await fetch('/api/search?q=top+hits+global+2024');
    const data = await res.json();
    cache.global = data.results || [];
    renderGrid(containerId, cache.global, 'global');
  } catch {
    document.getElementById(containerId).innerHTML = errorState();
  }
}

async function loadViewIndo() {
  if (cache.indo) { renderGrid('view-indo-grid', cache.indo, 'indo'); return; }
  await loadIndo('top-indo'); // trigger cache
  renderGrid('view-indo-grid', cache.indo || [], 'indo');
}

async function loadViewGlobal() {
  if (cache.global) { renderGrid('view-global-grid', cache.global, 'global'); return; }
  await loadGlobal('top-global');
  renderGrid('view-global-grid', cache.global || [], 'global');
}

function renderGrid(containerId, songs, queueId) {
  const el = document.getElementById(containerId);
  if (!el) return;
  if (!songs || !songs.length) { el.innerHTML = errorState(); return; }
  el.innerHTML = songs.map((s, i) => songCard(s, i, queueId)).join('');
}

// ============================================================
// SONG CARD HTML
// ============================================================
function songCard(song, index, queueId) {
  const isPlaying = currentSong && currentSong.id === song.id;
  return `
  <div class="song-card${isPlaying ? ' playing' : ''}" id="card-${song.id}" onclick="playSongFromQueue('${queueId}', ${index})">
    <div class="song-thumb-wrap">
      <img class="song-thumb" src="${song.thumbnail}" alt="" loading="lazy" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 160 90%22%3E%3Crect fill=%22%23181818%22 width=%22160%22 height=%2290%22/%3E%3Ctext x=%2250%25%22 y=%2250%25%22 dominant-baseline=%22middle%22 text-anchor=%22middle%22 fill=%22%233f3f46%22 font-size=%2228%22%3E♪%3C/text%3E%3C/svg%3E'" />
      <div class="play-overlay">
        <div class="play-icon-big">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#000"><path d="M8 5v14l11-7z"/></svg>
        </div>
      </div>
      ${isPlaying ? `<div style="position:absolute;bottom:5px;left:6px;"><div class="eq-bars"><div class="eq-bar"></div><div class="eq-bar"></div><div class="eq-bar"></div></div></div>` : ''}
    </div>
    <div class="song-info">
      <div class="song-title">${escHtml(song.title)}</div>
      <div class="song-artist">${escHtml(song.artist)}</div>
    </div>
    <div class="add-to-playlist-btn" onclick="event.stopPropagation();openPModal(${JSON.stringify(song).replace(/"/g,'&quot;')})" title="Tambah ke playlist">+</div>
  </div>`;
}

// ============================================================
// PLAYBACK
// ============================================================
const queues = {};

function getQueue(queueId) {
  if (queueId === 'search-results') return currentQueue;
  if (queueId === 'indo') return cache.indo || [];
  if (queueId === 'global') return cache.global || [];
  if (queueId === 'playlist') return playlists[currentPlaylistName] || [];
  return [];
}

async function playSongFromQueue(queueId, index) {
  const queue = getQueue(queueId);
  if (!queue || !queue[index]) return;
  currentQueue = queue;
  currentQueueIndex = index;
  await playSong(queue[index]);
}

async function playSong(song) {
  if (isLoading) return;
  isLoading = true;

  // Update UI immediately
  currentSong = song;
  updatePlayerBar(song);
  setPlayIcon(false);
  showToast(`⟳ Memuat: ${song.title}`);

  try {
    const res = await fetch(`/api/stream?id=${song.id}`);
    const data = await res.json();
    if (data.error) throw new Error(data.error);

    audio.src = data.streamUrl;
    audio.load();
    await audio.play();
    setPlayIcon(true);
    showToast(`▶ ${song.title}`);
  } catch (err) {
    showToast('⚠ Gagal stream: ' + err.message);
    setPlayIcon(false);
  } finally {
    isLoading = false;
    refreshAllCards();
  }
}

function updatePlayerBar(song) {
  document.getElementById('player-title').textContent = song.title;
  document.getElementById('player-artist').textContent = song.artist;
  document.getElementById('player-thumb').src = song.thumbnail || '';
}

function togglePlay() {
  if (!audio.src || audio.src === window.location.href) return;
  if (audio.paused) { audio.play(); setPlayIcon(true); }
  else { audio.pause(); setPlayIcon(false); }
}

function setPlayIcon(playing) {
  document.getElementById('play-icon').style.display = playing ? 'none' : 'block';
  document.getElementById('pause-icon').style.display = playing ? 'block' : 'none';
}

function nextSong() {
  if (!currentQueue.length) return;
  currentQueueIndex = (currentQueueIndex + 1) % currentQueue.length;
  playSong(currentQueue[currentQueueIndex]);
}

function prevSong() {
  if (!currentQueue.length) return;
  if (audio.currentTime > 3) { audio.currentTime = 0; return; }
  currentQueueIndex = (currentQueueIndex - 1 + currentQueue.length) % currentQueue.length;
  playSong(currentQueue[currentQueueIndex]);
}

// Audio events
audio.addEventListener('timeupdate', () => {
  if (!audio.duration) return;
  const pct = (audio.currentTime / audio.duration) * 100;
  const bar = document.getElementById('progress-bar');
  bar.value = pct;
  bar.style.setProperty('--progress', pct + '%');
  document.getElementById('time-current').textContent = formatTime(audio.currentTime);
  document.getElementById('time-total').textContent = formatTime(audio.duration);
});

audio.addEventListener('ended', nextSong);
audio.addEventListener('error', () => {
  showToast('⚠ Error memutar audio');
  setPlayIcon(false);
});

function seekTo(val) {
  if (audio.duration) {
    audio.currentTime = (val / 100) * audio.duration;
  }
}

function setVolume(val) {
  audio.volume = val / 100;
  updateVolumeTrack(val);
}

function updateVolumeTrack(val) {
  document.getElementById('volume-bar').style.setProperty('--vol', val + '%');
}

function formatTime(sec) {
  if (!sec || isNaN(sec)) return '0:00';
  const m = Math.floor(sec / 60);
  const s = Math.floor(sec % 60);
  return `${m}:${s.toString().padStart(2, '0')}`;
}

function refreshAllCards() {
  document.querySelectorAll('.song-card').forEach(card => {
    const id = card.id.replace('card-', '');
    const playing = currentSong && currentSong.id === id;
    card.classList.toggle('playing', playing);
  });
}

// ============================================================
// PLAYLIST SYSTEM
// ============================================================
function loadPlaylists() {
  const key = `meg_playlists_${currentUser}`;
  playlists = JSON.parse(localStorage.getItem(key) || '{}');
  renderSidebarPlaylists();
}

function savePlaylists() {
  const key = `meg_playlists_${currentUser}`;
  localStorage.setItem(key, JSON.stringify(playlists));
}

function renderSidebarPlaylists() {
  const el = document.getElementById('playlist-list');
  const names = Object.keys(playlists);
  if (!names.length) {
    el.innerHTML = `<div style="padding:8px 14px;color:var(--text3);font-size:10px;">Belum ada playlist</div>`;
    return;
  }
  el.innerHTML = names.map(name => `
    <div class="playlist-item${currentPlaylistName === name && currentView === 'playlist' ? ' active' : ''}" data-name="${escHtml(name)}" onclick="openPlaylistView('${escHtml(name)}')">
      <span class="playlist-name">▸ ${escHtml(name)}</span>
      <span class="playlist-count">${playlists[name].length}</span>
    </div>`).join('');
}

function openNewPLModal() {
  document.getElementById('newpl-input').value = '';
  document.getElementById('newpl-modal').classList.add('open');
  setTimeout(() => document.getElementById('newpl-input').focus(), 100);
}

function closeNewPLModal() {
  document.getElementById('newpl-modal').classList.remove('open');
}

document.getElementById('newpl-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') confirmNewPlaylist();
  if (e.key === 'Escape') closeNewPLModal();
});

function confirmNewPlaylist() {
  const name = document.getElementById('newpl-input').value.trim();
  if (!name) return;
  if (playlists[name]) { showToast('Nama playlist sudah ada!'); return; }
  playlists[name] = [];
  savePlaylists();
  renderSidebarPlaylists();
  closeNewPLModal();
  showToast(`✓ Playlist "${name}" dibuat!`);
  openPlaylistView(name);
}

function openPModal(song) {
  pendingSong = song;
  const names = Object.keys(playlists);
  const listEl = document.getElementById('pmodal-list');
  if (!names.length) {
    listEl.innerHTML = `<div style="color:var(--text2);font-size:11px;margin-bottom:10px;">Belum ada playlist. Buat dulu ya!</div>
      <button class="btn-em" style="width:100%" onclick="closePModal();openNewPLModal()">+ BUAT PLAYLIST</button>`;
  } else {
    listEl.innerHTML = names.map(name => `
      <div class="pmodal-item" onclick="addToPlaylist('${escHtml(name)}')">
        <span style="color:var(--em2)">▸</span>
        <span style="flex:1">${escHtml(name)}</span>
        <span style="color:var(--text3)">${playlists[name].length} lagu</span>
      </div>`).join('');
  }
  document.getElementById('playlist-modal').classList.add('open');
}

function closePModal() {
  document.getElementById('playlist-modal').classList.remove('open');
  pendingSong = null;
}

function addToPlaylist(name) {
  if (!pendingSong) return;
  const exists = playlists[name].some(s => s.id === pendingSong.id);
  if (exists) { showToast(`"${pendingSong.title}" sudah ada di playlist!`); closePModal(); return; }
  playlists[name].push(pendingSong);
  savePlaylists();
  renderSidebarPlaylists();
  showToast(`✓ Ditambahkan ke "${name}"`);
  closePModal();
  if (currentPlaylistName === name && currentView === 'playlist') renderPlaylistSongs(name);
}

function renderPlaylistSongs(name) {
  const songs = playlists[name] || [];
  const el = document.getElementById('playlist-songs');
  if (!songs.length) {
    el.innerHTML = `<div class="empty-state" style="grid-column:1/-1"><div class="empty-icon">🎵</div><div class="empty-title">Playlist kosong</div><div class="empty-sub">Tambah lagu dari hasil pencarian</div></div>`;
    return;
  }
  // set queue for playlist
  el.innerHTML = songs.map((s, i) => songCard(s, i, 'playlist')).join('');
}

function deletePlaylist() {
  if (!confirm(`Hapus playlist "${currentPlaylistName}"?`)) return;
  delete playlists[currentPlaylistName];
  savePlaylists();
  renderSidebarPlaylists();
  currentPlaylistName = '';
  navigate('home');
  showToast('Playlist dihapus');
}

// ============================================================
// UTILS
// ============================================================
function showToast(msg, duration = 2500) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(() => t.classList.remove('show'), duration);
}

function escHtml(str) {
  return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

function errorState() {
  return `<div class="empty-state" style="grid-column:1/-1"><div class="empty-icon">⚠</div><div class="empty-title">Gagal memuat</div><div class="empty-sub">Periksa koneksi dan coba lagi</div></div>`;
}

// Close modals on overlay click
document.getElementById('playlist-modal').addEventListener('click', function(e) {
  if (e.target === this) closePModal();
});
document.getElementById('newpl-modal').addEventListener('click', function(e) {
  if (e.target === this) closeNewPLModal();
});
</script>
</body>
</html>
